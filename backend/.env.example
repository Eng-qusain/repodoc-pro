# ─── RepoDoc Pro — Backend Environment Variables ─────────────────────────────
# Copy this file to backend/.env and fill in values.
# Never commit .env with real API keys.

# ─── Server ──────────────────────────────────────────────────────────────────
REPODOC_ENV=development          # development | production
REPODOC_PORT=8765
REPODOC_HOST=127.0.0.1
REPODOC_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ─── Paths ───────────────────────────────────────────────────────────────────
REPODOC_TEMP_DIR=/tmp/repodoc
REPODOC_OUTPUT_DIR=~/Documents/RepoDoc

# ─── AI Documentation ────────────────────────────────────────────────────────
# At least one key required for AI documentation features.
# Anthropic Claude is used as primary; OpenAI as fallback.
REPODOC_AI_ENABLED=true
REPODOC_AI_MODEL=claude-3-5-haiku-20241022

# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...

# ─── Performance ─────────────────────────────────────────────────────────────
REPODOC_MAX_FILE_SIZE_MB=50      # Files larger than this are treated as binary
REPODOC_MAX_WORKERS=4            # Concurrent background workers
REPODOC_SCAN_CHUNK_SIZE=500      # Files processed per async chunk

# ─── PDF ─────────────────────────────────────────────────────────────────────
REPODOC_PDF_ENGINE=reportlab     # reportlab | weasyprint
